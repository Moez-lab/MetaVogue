# Copy this file to .env and fill in your values
# .env is git-ignored — never commit secrets

# Port for the Express server (default: 3001)
PORT=3001

# Optional: override the Python executable path
# If not set, the server auto-detects the conda feature-extractor env or falls back to system python
# PYTHON_PATH=C:\Users\yourname\anaconda3\envs\feature-extractor\python.exe
